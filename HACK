def apply_background(widget, color=SURFACE):
    """Paint a solid background for any root container."""
    widget.canvas.before.clear()
    with widget.canvas.before:
        Color(*color)
        bg = Rectangle(pos=widget.pos, size=widget.size)
    widget.bind(pos=lambda *_: setattr(bg, "pos", widget.pos))
    widget.bind(size=lambda *_: setattr(bg, "size", widget.size))
    return bg

def primary_button(text, on_press=None, height=dp(52), full=True):
    """Material-like primary button."""
    btn = Button(
        text=text,
        size_hint=(1 if full else None, None),
        height=height,
        background_normal="",
        background_color=PRIMARY,
        color=TEXT
    )
    if on_press: btn.bind(on_press=on_press)
    return btn

def outline_button(text, on_press=None, height=dp(48), full=True):
    """Flat outlined button."""
    btn = Button(
        text=text,
        size_hint=(1 if full else None, None),
        height=height,
        background_normal="",
        background_color=(0,0,0,0),
        color=TEXT
    )
    with btn.canvas.before:
        Color(1,1,1,0.18)
        rect = RoundedRectangle(radius=[dp(10)], pos=btn.pos, size=btn.size)
        Color(1,1,1,0.25)
        line = Line(rounded_rectangle=[btn.x, btn.y, btn.width, btn.height, dp(10)], width=1.1)
    def _sync(*_):
        rect.pos = btn.pos; rect.size = btn.size
        line.rounded_rectangle = [btn.x, btn.y, btn.width, btn.height, dp(10)]
    btn.bind(pos=_sync, size=_sync)
    if on_press: btn.bind(on_press=on_press)
    return btn

def card_container(pad=dp(12)):
    """Rounded card container for long text."""
    box = BoxLayout(orientation="vertical", padding=pad, size_hint=(1, None))
    with box.canvas.before:
        Color(*CARD_BG)
        bg = RoundedRectangle(radius=[dp(12)], pos=box.pos, size=box.size)
    box.bind(pos=lambda *_: setattr(bg, "pos", box.pos))
    box.bind(size=lambda *_: setattr(bg, "size", box.size))
    return box

def set_feedback_chip(label, ok: bool, text: str):
    """Color chip behind feedback text (green/red)."""
    label.canvas.before.clear()
    with label.canvas.before:
        Color(*( (0.56, 0.91, 0.64, 1) if ok else (1.0, 0.65, 0.65, 1) ))
        bg = RoundedRectangle(radius=[dp(10)], pos=label.pos, size=label.size)
    def _sync(*_):
        bg.pos = label.pos; bg.size = label.size
    label.bind(pos=_sync, size=_sync)
    label.text = text
    label.color = (0,0,0,1)  # dark text on light chip

def toast(parent, msg: str, secs=1.5):
    """Tiny toast in the corner (optional helper)."""
    lbl = Label(text=msg, size_hint=(None, None), color=(1,1,1,1))
    lbl.texture_update()
    lbl.size = (lbl.texture_size[0] + dp(24), lbl.texture_size[1] + dp(14))
    with lbl.canvas.before:
        Color(0,0,0,0.78)
        bg = RoundedRectangle(radius=[dp(12)], pos=lbl.pos, size=lbl.size)
    def _sync(*_):
        bg.pos = lbl.pos; bg.size = lbl.size
    lbl.bind(pos=_sync, size=_sync)
    parent.add_widget(lbl)
    def _place(*_):
        lbl.pos = (parent.width - lbl.width - dp(16), parent.height - lbl.height - dp(16))
    parent.bind(size=_place); Clock.schedule_once(_place, 0)
    Clock.schedule_once(lambda *_: parent.remove_widget(lbl), secs)

