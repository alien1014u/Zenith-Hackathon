class MainMenu(Screen):
    def on_enter(self):
        self.clear_widgets()
        layout = BoxLayout(orientation="vertical", padding=dp(12), spacing=dp(10))
        apply_background(layout)

        title = Label(text="[b]Learning Levels[/b]", markup=True, color=TEXT,
                      size_hint_y=None, height=dp(56))
        subtitle = Label(text="Choose a level to get started", color=SUBTEXT,
                         size_hint_y=None, height=dp(28))
        layout.add_widget(title)
        layout.add_widget(subtitle)

        for level in app_data.keys():
            btn = primary_button(level, on_press=lambda x, l=level: self.open_level(l))
            layout.add_widget(btn)

        self.add_widget(layout)

    def open_level(self, level_name):
        from kivy.uix.screenmanager import SlideTransition
        self.manager.transition = SlideTransition(direction="left", duration=0.18)
        self.manager.current = level_name


class LevelScreen(Screen):
    def __init__(self, level_name, **kwargs):
        super().__init__(name=level_name, **kwargs)
        layout = BoxLayout(orientation="vertical", padding=dp(12), spacing=dp(10))
        apply_background(layout)

        title = Label(text=f"[b]{level_name}[/b]", markup=True, color=TEXT,
                      size_hint_y=None, height=dp(56))
        subtitle = Label(text="Select a lesson", color=SUBTEXT,
                         size_hint_y=None, height=dp(28))
        layout.add_widget(title)
        layout.add_widget(subtitle)

        for lesson in app_data[level_name].keys():
            btn = outline_button(lesson, on_press=lambda x, l=lesson: self.open_lesson(l))
            layout.add_widget(btn)

        self.add_widget(layout)
        self.level_name = level_name

    def open_lesson(self, lesson_name):
        from kivy.uix.screenmanager import SlideTransition
        self.manager.transition = SlideTransition(direction="left", duration=0.18)
        self.manager.current = f"{self.level_name}-{lesson_name}"


class LessonScreen(Screen):
    def __init__(self, level_name, lesson_name, lesson_data, **kwargs):
        super().__init__(name=f"{level_name}-{lesson_name}", **kwargs)

        root = BoxLayout(orientation="vertical", padding=dp(12), spacing=dp(10))
        apply_background(root)

        title = Label(text=f"[b]{lesson_name}[/b]", markup=True, color=TEXT,
                      size_hint_y=None, height=dp(52))
        root.add_widget(title)

        # Scrollable card with wrapped content
        scroll = ScrollView(size_hint=(1, 1))
        card = card_container(pad=dp(12))
        content = Label(
            text=lesson_data.get("content", "Add content here."),
            size_hint=(1, None),
            halign="left",
            valign="top",
            color=TEXT
        )
        def _wrap(*_):
            content.text_size = (card.width - dp(24), None)
            content.texture_update()
            content.height = content.texture_size[1]
            card.height = content.height + dp(24)
        card.bind(width=_wrap); Clock.schedule_once(_wrap, 0)

        card.add_widget(content)
        scroll.add_widget(card)
        root.add_widget(scroll)

        start_btn = primary_button("Start Quiz", on_press=lambda *_: self.start_quiz(level_name, lesson_name))
        root.add_widget(start_btn)

        self.add_widget(root)

    def start_quiz(self, level_name, lesson_name):
        from kivy.uix.screenmanager import SlideTransition
        self.manager.transition = SlideTransition(direction="left", duration=0.18)
        self.manager.current = f"quiz-{level_name}-{lesson_name}"


class QuizScreen(Screen):
    def __init__(self, level_name, lesson_name, lesson_data, **kwargs):
        super().__init__(name=f"quiz-{level_name}-{lesson_name}", **kwargs)

        self.level_name = level_name
        self.lesson_name = lesson_name
        self.questions = lesson_data.get("questions", [])
        self.q_index = 0
        self.score = 0
        self.answered = False
        self.option_buttons = []

        # Root vertical layout
        self.root_box = BoxLayout(orientation="vertical", spacing=8, padding=(10, 10, 10, 10))
        apply_background(self.root_box)
        self.add_widget(self.root_box)

        # --- Title / Top bar ---
        top_bar = BoxLayout(orientation="horizontal", size_hint_y=None, height=48, spacing=8)
        self.title_lbl = Label(text=f"Quiz: {lesson_name}", halign="left", valign="middle")
        self.title_lbl.bind(size=lambda i, v: setattr(i, "text_size", v))
        top_bar.add_widget(self.title_lbl)
        self.root_box.add_widget(top_bar)

        # --- Question area (scrollable) ---
        self.q_scroll = ScrollView(size_hint=(1, 0.50), do_scroll_x=False)
        self.q_container = BoxLayout(orientation="vertical", size_hint=(1, None), padding=(6, 6, 6, 6))
        self.q_container.bind(minimum_height=self.q_container.setter("height"))

        self.question_lbl = Label(
            text="",
            size_hint=(1, None),
            halign="left",
            valign="top",
        )
        self.q_container.add_widget(self.question_lbl)
        self.q_scroll.add_widget(self.q_container)
        self.root_box.add_widget(self.q_scroll)

        # --- Options (buttons) ---
        self.options_box = GridLayout(cols=1, spacing=8, size_hint=(1, None))
        self.options_box.height = 4 * 52  # default; recalculated per question
        self.root_box.add_widget(self.options_box)

        # --- Feedback (short, non-scroll) ---
        self.feedback_lbl = Label(
            text="",
            size_hint=(1, None),
            height=70,
            halign="left",
            valign="top",
        )
        self.feedback_lbl.bind(size=lambda i, v: setattr(i, "text_size", (v[0]-10, None)))
        self.root_box.add_widget(self.feedback_lbl)

        # --- Bottom bar (Next) ---
        bottom_bar = BoxLayout(orientation="horizontal", size_hint_y=None, height=56, spacing=8)
        bottom_bar.add_widget(Widget())  # spacer
        self.next_btn = Button(text="Next", disabled=True, size_hint_x=None, width=120)
        self.next_btn.bind(on_press=lambda *_: self.goto_next())
        bottom_bar.add_widget(self.next_btn)
        self.root_box.add_widget(bottom_bar)

        # Wrap the question when width changes
        self.root_box.bind(width=lambda *_: self._wrap_question())
        Clock.schedule_once(lambda *_: self._wrap_question(), 0)

        # Render first question
        self.render_question()

    # ---------- UI helpers ----------
    def _wrap_question(self):
        avail_w = max(0, self.root_box.width - 30)  # account for padding
        self.question_lbl.text_size = (avail_w, None)
        self.question_lbl.texture_update()
        self.question_lbl.height = self.question_lbl.texture_size[1] + 10

    def _update_options_height(self, num_options):
        btn_h = 48
        spacing = 8
        self.options_box.height = num_options * btn_h + max(0, (num_options - 1)) * spacing

    # ---------- Screen building ----------
    def render_question(self):
        self.answered = False
        self.next_btn.text = "Next"
        self.next_btn.disabled = True
        self.feedback_lbl.text = ""

        if not self.questions:
            self.title_lbl.text = f"Quiz: {self.lesson_name}"
            self.question_lbl.text = "No questions found."
            self.options_box.clear_widgets()
            return

        q = self.questions[self.q_index]
        total = len(self.questions)
        self.title_lbl.text = f"Quiz: {self.lesson_name}   (Q {self.q_index + 1}/{total})"
        self.question_lbl.text = q["question"]
        self._wrap_question()

        # Build options
        self.options_box.clear_widgets()
        self.option_buttons = []
        for idx, option in enumerate(q["options"]):
            btn = Button(text=option, size_hint_y=None, height=48)
            btn.bind(on_press=lambda x, i=idx, q=q: self.check_answer(i, q))
            self.options_box.add_widget(btn)
            self.option_buttons.append(btn)

        self._update_options_height(len(self.option_buttons))

    # ---------- Answer handling ----------
    def check_answer(self, selected, question):
        if self.answered:
            return

        correct = (selected == question["answer"])
        verdict = "✅ Correct!" if correct else "❌ Wrong!"
        explanation = question.get("explanation", "")

        # Disable options after answering
        for b in self.option_buttons:
            b.disabled = True

        self.answered = True

        # Use the green/red chip for feedback
        set_feedback_chip(self.feedback_lbl, correct, f"{verdict}\n{explanation}")

        # If last question -> go to next lesson/main after a short pause
        if self.q_index == len(self.questions) - 1:
            Clock.schedule_once(lambda *_: self.navigate_to_next_lesson(), 0.8)
            self.next_btn.text = "Finish"
            self.next_btn.disabled = False
            return

        # Not the last question
        if correct:
            # Auto-advance after short delay
            self.next_btn.text = "Next"
            self.next_btn.disabled = True
            Clock.schedule_once(lambda *_: self.goto_next(), 0.6)
        else:
            # Let the user tap Next after reading
            self.next_btn.text = "Next"
            self.next_btn.disabled = False

    def goto_next(self):
        if not self.answered:
            return
        self.q_index += 1
        if self.q_index >= len(self.questions):
            self.navigate_to_next_lesson()
        else:
            self.render_question()

    # ---------- Navigation to next lesson OR Main Menu ----------
    def navigate_to_next_lesson(self):
        """
        Go to the next lesson in the same level.
        If there are no more lessons in this level, go to the Main Menu ("main").
        """
        try:
            lessons_in_level = list(app_data[self.level_name].keys())
            current_idx = lessons_in_level.index(self.lesson_name)
            next_idx = current_idx + 1
            if next_idx < len(lessons_in_level):
                # There is a next lesson -> open it
                next_lesson = lessons_in_level[next_idx]
                self.manager.current = f"{self.level_name}-{next_lesson}"
            else:
                # No more lessons in this level -> go to Levels screen (Main Menu)
                self.manager.current = "main"
        except Exception:
            # Fallback: go to Main Menu
            self.manager.current = "main"

    # (Optional) Summary kept for reuse if needed
    def show_summary(self):
        total = len(self.questions)
        summary_text = f"You scored {self.score} / {total}\n\nTap Finish to go back."
        self.feedback_lbl.text = summary_text

    def restart_quiz(self):
        self.q_index = 0
        self.score = 0
        self.render_question()


class LearningApp(App):
    def build(self):
        sm = ScreenManager()
        sm.add_widget(MainMenu(name="main"))

        for level_name, lessons in app_data.items():
            sm.add_widget(LevelScreen(level_name))
            for lesson_name, lesson_data in lessons.items():
                sm.add_widget(LessonScreen(level_name, lesson_name, lesson_data))
                sm.add_widget(QuizScreen(level_name, lesson_name, lesson_data))

        sm.current = "main"
        return sm


if __name__ == "__main__":
    LearningApp().run()
