class Dashboard(Screen):

    def __init__(self, app_ref, **kwargs):
        super().__init__(**kwargs)
        self.app_ref = app_ref
        self.layout = BoxLayout(orientation="vertical")
        self.add_widget(self.layout)
        self.refresh()

    def refresh(self):
        self.layout.clear_widgets()

        title = Label(text="Financial Literacy Dashboard", size_hint_y=None, height=60)
        self.layout.add_widget(title)

        for level in range(1, 8):

            unlocked = self.app_ref.is_level_unlocked(level)

            if unlocked:
                btn = Button(text=level_names[level])
                btn.bind(on_press=lambda x, lvl=level: self.open_level(lvl))
            else:
                btn = Button(text=level_names[level] + " (Locked)")

            self.layout.add_widget(btn)

    def open_level(self, level):
        self.app_ref.current_level = level
        self.manager.current = "level"


class LevelScreen(Screen):

    def __init__(self, app_ref, **kwargs):
        super().__init__(**kwargs)
        self.app_ref = app_ref
        self.layout = BoxLayout(orientation="vertical")
        self.add_widget(self.layout)

    def on_enter(self):

        self.layout.clear_widgets()

        level = self.app_ref.current_level

        title = Label(text=level_names[level])
        self.layout.add_widget(title)

        for lesson in range(1, 6):

            completed = self.app_ref.is_lesson_completed(level, lesson)

            text = f"Lesson {lesson}"
            if completed:
                text += " ✓"

            btn = Button(text=text)
            btn.bind(on_press=lambda x, l=lesson: self.open_lesson(l))
            self.layout.add_widget(btn)

        back = Button(text="Back")
        back.bind(on_press=lambda x: self.go_back())
        self.layout.add_widget(back)

    def open_lesson(self, lesson):
        self.app_ref.current_lesson = lesson
        self.manager.current = "lesson"

    def go_back(self):
        self.manager.current = "dashboard"


class LessonScreen(Screen):

    def __init__(self, app_ref, **kwargs):
        super().__init__(**kwargs)
        self.app_ref = app_ref
        self.layout = BoxLayout(orientation="vertical")
        self.add_widget(self.layout)

    def on_enter(self):

        self.layout.clear_widgets()

        level = self.app_ref.current_level
        lesson = self.app_ref.current_lesson

        label = Label(text=f"Level {level} - Lesson {lesson}")
        self.layout.add_widget(label)

        content = Label(text="Add your lesson content here")
        self.layout.add_widget(content)

        complete = Button(text="Mark Lesson Complete")
        complete.bind(on_press=lambda x: self.complete_lesson())
        self.layout.add_widget(complete)

        back = Button(text="Back")
        back.bind(on_press=lambda x: self.go_back())
        self.layout.add_widget(back)

    def complete_lesson(self):

        level = self.app_ref.current_level
        lesson = self.app_ref.current_lesson

        self.app_ref.complete_lesson(level, lesson)

    def go_back(self):
        self.manager.current = "level"


class LearningApp(App):

    def build(self):

        self.completed_lessons = {
            1: [1, 2],
            2: [1],
            3: [],
            4: [],
            5: [],
            6: [],
            7: []
        }

        self.current_level = None
        self.current_lesson = None

        sm = ScreenManager()

        sm.add_widget(Dashboard(self, name="dashboard"))
        sm.add_widget(LevelScreen(self, name="level"))
        sm.add_widget(LessonScreen(self, name="lesson"))

        return sm

    def is_level_unlocked(self, level):

        if level == 1:
            return True

        previous = level - 1

        return len(self.completed_lessons.get(previous, [])) == 5

    def is_lesson_completed(self, level, lesson):

        return lesson in self.completed_lessons.get(level, [])

    def complete_lesson(self, level, lesson):

        lessons = self.completed_lessons[level]

        if lesson not in lessons:
            lessons.append(lesson)


if __name__ == "__main__":
    LearningApp().run()
